{
  "name": "axhub-make",
  "version": "0.3.4",
  "private": true,
  "description": "Axhub Make（AI 辅助生成原型工具）",
  "type": "module",
  "scripts": {
    "vendor:sync": "node scripts/sync-vendor-package.mjs",
    "dev": "pnpm vendor:sync && vite",
    "start": "pnpm vendor:sync && vite",
    "build": "pnpm vendor:sync && node scripts/scan-entries.js && node scripts/build-all.js && node scripts/generate-dist-html.js",
    "preview": "vite preview",
    "typecheck": "pnpm vendor:sync && tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "check-ready": "node scripts/check-app-ready.mjs",
    "sync:skills": "node scripts/sync-third-party-skills.mjs"
  },
  "devDependencies": {
    "@ant-design/cssinjs": "^2.1.0",
    "@ant-design/icons": "^6.1.0",
    "@floating-ui/react": "^0.27.17",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@tailwindcss/vite": "^4.1.18",
    "@tiptap/core": "^3.19.0",
    "@tiptap/extension-highlight": "^3.19.0",
    "@tiptap/extension-horizontal-rule": "^3.19.0",
    "@tiptap/extension-image": "^3.19.0",
    "@tiptap/extension-list": "^3.19.0",
    "@tiptap/extension-subscript": "^3.19.0",
    "@tiptap/extension-superscript": "^3.19.0",
    "@tiptap/extension-table": "^3.19.0",
    "@tiptap/extension-text-align": "^3.19.0",
    "@tiptap/extension-typography": "^3.19.0",
    "@tiptap/extensions": "^3.19.0",
    "@tiptap/markdown": "^3.19.0",
    "@tiptap/pm": "^3.19.0",
    "@tiptap/react": "^3.19.0",
    "@tiptap/starter-kit": "^3.19.0",
    "@vitejs/plugin-react": "^5.0.0",
    "antd": "^6.1.2",
    "echarts": "^6.0.0",
    "execa": "^9.6.1",
    "lodash.throttle": "^4.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hotkeys-hook": "^5.2.4",
    "sass": "^1.97.3",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^5.0.0",
    "vitest": "^4.0.16",
    "ws": "^8.18.3"
  },
  "dependencies": {
    "@tailwindcss/oxide-win32-x64-msvc": "^4.2.4",
    "archiver": "^7.0.1",
    "extract-zip": "^2.0.1",
    "formidable": "^3.5.4",
    "iconv-lite": "^0.7.1",
    "lowdb": "^7.0.1",
    "lucide-react": "^0.562.0",
    "motion": "^12.38.0",
    "papaparse": "^5.5.3",
    "uuid": "^13.0.0"
  }
}
